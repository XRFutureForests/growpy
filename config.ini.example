# GrowPy Configuration File
# This file allows customization of tree generation parameters for the generate_forest script
# Copy this file to 'config.ini' and modify the values as needed

[simulation]
# Number of cycles used specifically for height curve generation
# This determines how many growth cycles are simulated to create height models
height_model_cycles = 75


# Random seed for reproducible results (set to 'none' for random behavior)
random_seed = 42

# Note: age_to_cycle_ratio removed to avoid growth timing issues
# Use height_model_cycles to control simulation time instead

[output]
# Base output directory for all generated files
output_dir = data/output

[build]
# LOD (Level of Detail) configuration
# Specify which LOD levels to generate (comma-separated)
# Available levels: LOD0_Ultra, LOD1_High, LOD2_Medium, LOD3_Low, LOD4_VeryLow, LOD5_Minimal
# Use 'all' to generate all LOD levels, or specify specific levels for single/subset generation
# Examples:
#   lod_levels = all                    # Generate all 6 LOD levels
#   lod_levels = LOD1_High              # Generate only high quality model
#   lod_levels = LOD2_Medium, LOD3_Low  # Generate medium and low quality models
lod_levels = all
