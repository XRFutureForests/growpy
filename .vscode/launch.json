    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: Generate Forest (test.csv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/growpy/cli/generate_forest.py",
            "console": "integratedTerminal",
            "args": [
                "data/input/test.csv",
                "--quality",
                "high",
                "--growth-cycle-limit",
                "5"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/src/the_grove_22/modules"
            }
        },
    ]
}