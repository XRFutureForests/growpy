        rel prototypes = </Scene/PyramidInstances/Prototypes/Pyramid>
        
        point3f[] positions = [
            (-1.5, -1.5, 0.48), (1.5, -1.5, 0.48), (-0.5, 0, 0.96), (0.5, 0, 0.96),
