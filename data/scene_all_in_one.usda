        int[] faceVertexIndices = [
            0, 1, 7, 6,    1, 2, 8, 7,    2, 3, 9, 8,    3, 4, 10, 9,    4, 5, 11, 10,
            6, 7, 13, 12,  7, 8, 14, 13,  8, 9, 15, 14,  9, 10, 16, 15,  10, 11, 17, 16,
