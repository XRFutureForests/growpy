    def Scope "_materials"
    {
        def Material "TheGroveBranches"
        {
            token outputs:surface.connect = </root/_materials/TheGroveBranches/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "TheGroveBranches"
            custom string userProperties:original_name = "TheGroveBranches"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/TheGroveBranches/Bark_Texture.outputs:rgb>
                float inputs:ior = 1.4
                float inputs:metallic = 0
                normal3f inputs:normal.connect = </root/_materials/TheGroveBranches/Bark_Normal.outputs:rgb>
                float inputs:opacity = 1
                float inputs:roughness = 0.75
                float inputs:specular = 0.35
                token outputs:surface
            }

            def Shader "Bark_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/Beech60.jpg@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/TheGroveBranches/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "Bark_Normal"
            {
                uniform token info:id = "UsdUVTexture"
                float4 inputs:bias = (-1, -1, -1, -1)
                asset inputs:file = @./textures/Beech60Normal.jpg@
                float4 inputs:scale = (2, 2, 2, 2)
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/TheGroveBranches/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }
        }
    }
}

