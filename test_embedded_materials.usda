#usda 1.0
(
    doc = """Generated from Composed Stage of root layer 
"""
)

def Scope "materials"
{
    def Material "MannaGumTwig"
    {
        token outputs:surface.connect = </materials/MannaGumTwig/Diffuse_BSDF.outputs:surface>

        def Shader "Diffuse_BSDF"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor.connect = </materials/MannaGumTwig/Image_Texture.outputs:rgb>
            float inputs:roughness = 0
            token outputs:surface
        }

        def Shader "Image_Texture"
        {
            uniform token info:id = "UsdUVTexture"
            asset inputs:file = @./textures/MannaGumTop.png@
            string inputs:sourceColorSpace = "sRGB"
            float2 inputs:st.connect = </materials/MannaGumTwig/uvmap.outputs:result>
            string inputs:wrapS = "repeat"
            string inputs:wrapT = "repeat"
            color3f outputs:rgb
        }

        def Shader "uvmap"
        {
            uniform token info:id = "UsdPrimvarReader_float2"
            string inputs:varname = "st"
            float2 outputs:result
        }
    }

    def Material "MannaGumLeaf"
    {
        token outputs:surface.connect = </materials/MannaGumLeaf/Diffuse_BSDF.outputs:surface>

        def Shader "Diffuse_BSDF"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor.connect = </materials/MannaGumLeaf/Image_Texture.outputs:rgb>
            float inputs:roughness = 0
            token outputs:surface
        }

        def Shader "Image_Texture"
        {
            uniform token info:id = "UsdUVTexture"
            asset inputs:file = @./textures/MannaGumTop.png@
            string inputs:sourceColorSpace = "sRGB"
            float2 inputs:st.connect = </materials/MannaGumLeaf/uvmap.outputs:result>
            string inputs:wrapS = "repeat"
            string inputs:wrapT = "repeat"
            color3f outputs:rgb
        }

        def Shader "uvmap"
        {
            uniform token info:id = "UsdPrimvarReader_float2"
            string inputs:varname = "st"
            float2 outputs:result
        }
    }
}

